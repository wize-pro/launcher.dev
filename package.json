{
  "name": "dev-launcher",
  "version": "0.1.0",
  "description": "Local web launcher for dev projects",
  "main": "main.js",
  "author": "wize-pro",
  "license": "MIT",
  "keywords": [
    "launcher",
    "developer-tools",
    "electron",
    "tray",
    "project-manager"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "app": "electron .",
    "app:dev": "NODE_ENV=development electron .",
    "test": "node --test",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "express": "^4.18.2",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "dev.wize.launcher",
    "productName": "Dev Launcher",
    "files": [
      "main.js",
      "server.js",
      "launcher.config.js",
      "public/**/*",
      "locales/**/*",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/app-icon.png",
      "target": ["dmg", "zip"]
    },
    "win": {
      "icon": "assets/app-icon.png",
      "target": ["nsis"]
    },
    "linux": {
      "icon": "assets/app-icon.png",
      "target": ["AppImage"],
      "category": "Development"
    }
  }
}
